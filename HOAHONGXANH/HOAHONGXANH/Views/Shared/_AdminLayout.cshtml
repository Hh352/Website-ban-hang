<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản Trị Hệ Thống</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/HOAHONGXANH.styles.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100 bg-light">
    <!-- Main Header (Duplicate from _Layout for Admin consistency) -->
    <header class="sticky-top bg-white border-bottom shadow-sm">
        <div class="container py-1">
            <div class="row align-items-center">
                <!-- Mega Menu Button Placeholder -->
                <div class="col-md-3 d-flex align-items-center">
                    <button class="btn btn-outline-dark rounded-0 px-3 py-2 fw-bold d-flex align-items-center text-uppercase border-0" type="button">
                         <span style="letter-spacing: 1px;">DANH MỤC</span> <i class="bi bi-chevron-down ms-2 small"></i>
                    </button>
                </div>

                <!-- Center: Logo -->
                <div class="col-md-6 text-center">
                    <a href="/" class="text-decoration-none">
                        <img src="@Url.Content("~/images/logo.png")" alt="HOAHONGXANH" style="height: 50px; width: auto; object-fit: contain;">
                    </a>
                </div>

                <!-- Right: Admin Actions -->
                <div class="col-md-3 d-flex justify-content-end align-items-center gap-3">
                     <a href="/" class="btn btn-outline-dark rounded-pill fw-bold text-nowrap" style="font-size: 0.8rem;">
                        <i class="bi bi-shop me-2"></i>VỀ TRANG CHỦ
                    </a>
                    <div class="dropdown">
                        <a href="#" class="text-dark fs-5" id="userDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-person-circle"></i>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                             <li><a class="dropdown-item" href="/Admin/Logout">Đăng xuất</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <div class="container-fluid p-0">
        <div class="row g-0 flex-nowrap">
            <!-- Sidebar (Deskboard Theme) -->
            <nav class="col-md-2 d-none d-md-block db-sidebar p-0" style="min-height: calc(100vh - 70px);">
                <div class="p-4">
                    <div class="db-logo mb-5">
                         <i class="bi bi-grid-1x2-fill text-warning me-2 fs-4"></i> DESKBOARD
                    </div>

                    <div class="db-menu-label">DANH MỤC CHÍNH</div>
                    
                    <a class="db-nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Dashboard" ? "active" : "")" href="/Admin/Dashboard">
                        <i class="bi bi-grid-fill"></i> Tổng quan
                    </a>
                    <a class="db-nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "ProductManagement" ? "active" : "")" href="/Admin/ProductManagement">
                        <i class="bi bi-box-seam"></i> Sản phẩm
                    </a>
                     <a class="db-nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "OrderManagement" ? "active" : "")" href="/Admin/OrderManagement">
                        <i class="bi bi-file-earmark-text"></i> Hóa đơn
                         <span class="badge bg-danger rounded-pill ms-auto" style="font-size: 0.6rem;">1</span>
                    </a>
                    
                    <div class="mt-5 pt-5">
                        <a class="db-nav-link text-white" href="/Admin/Logout">
                            <i class="bi bi-box-arrow-left"></i> Đăng xuất
                        </a>
                    </div>
                </div>
            </nav>

            <!-- Main Content -->
            <main class="col-md-10 ms-sm-auto px-4 py-4" style="background-color: #F5F6FA; min-height: calc(100vh - 70px);">
                <!-- Header -->
                <div class="d-flex justify-content-between align-items-center mb-5 pt-2">
                    <div>
                         <h4 class="fw-bold m-0">Chào mừng trở lại, Admin 👋</h4>
                    </div>
                    
                    <div class="d-flex align-items-center gap-4">
                        <div class="bg-white rounded p-2 px-3 shadow-sm d-flex align-items-center" style="width: 300px;">
                            <i class="bi bi-search text-muted me-2"></i>
                             <input type="text" class="border-0 bg-transparent w-100" placeholder="Tìm kiếm..." style="outline: none;">
                        </div>
                        
                        <div class="d-flex gap-3 align-items-center">
                            <button class="btn btn-white border-0 position-relative p-0"><i class="bi bi-chat-dots fs-5 text-muted"></i></button>
                            <button class="btn btn-white border-0 position-relative p-0"><i class="bi bi-bell fs-5 text-muted"></i></button>
                            

                        </div>
                    </div>
                </div>

                @RenderBody()
            </main>
        </div>
    </div>
    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
