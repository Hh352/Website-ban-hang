<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HOAHONGXANH</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/HOAHONGXANH.styles.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">
    <header class="sticky-top bg-white border-bottom shadow-sm">
        <div class="container py-1">
            <div class="row align-items-center">
                <!-- Mega Menu Button (Updated Style) -->
                <div class="col-md-3 d-flex align-items-center">
                    <div class="dropdown mega-dropdown position-static">
                        <button class="btn btn-outline-dark rounded-0 px-3 py-2 fw-bold d-flex align-items-center text-uppercase border-0" type="button" id="megaMenuBtn" onclick="toggleMegaMenu()">
                             <span style="letter-spacing: 1px;">DANH MỤC</span> <i class="bi bi-chevron-down ms-2 small"></i>
                        </button>
                        
                        <!-- Mega Menu Content -->
                        <div class="dropdown-menu mega-menu p-4 shadow-lg border-0" id="megaMenuContent">
                            <div class="container-fluid">
                                <!-- All Products Section -->
                                <div class="row mb-3 border-bottom pb-2">
                                    <div class="col-12">
                                        <a href="/Products/Index" class="text-decoration-none fw-bold fs-5 d-flex align-items-center hover-link text-uppercase text-dark">
                                            <i class="bi bi-grid-fill me-2"></i> Tất Cả Sản Phẩm
                                        </a>
                                    </div>
                                </div>
                                <div class="row">
                                    <!-- NAM Column -->
                                    <div class="col-md-4">
                                        <h6 class="fw-bold text-uppercase mb-3 border-bottom pb-2">Nam <i class="bi bi-arrow-up-right small"></i></h6>
                                        <ul class="list-unstyled">
                                            <!-- Áo Nam -->
                                            <li class="mb-2">
                                                <div class="d-flex justify-content-between align-items-center menu-toggle" data-bs-toggle="collapse" data-bs-target="#collapseAoNam" aria-expanded="false" onclick="event.stopPropagation()">
                                                    <span>Áo nam</span>
                                                    <i class="bi bi-chevron-down small"></i>
                                                </div>
                                                <div class="collapse ps-3 mt-1" id="collapseAoNam">
                                                    <a href="/Products/Index?keyword=Áo Nam" class="d-block nested-menu-link py-1">Tất cả Áo nam</a>
                                                    <a href="/Products/Index?categoryId=1" class="d-block nested-menu-link py-1">Áo polo nam</a>
                                                    <a href="/Products/Index?categoryId=2" class="d-block nested-menu-link py-1">Áo sơ mi nam</a>
                                                    <a href="/Products/Index?categoryId=3" class="d-block nested-menu-link py-1">Áo thun nam</a>
                                                    <a href="/Products/Index?categoryId=4" class="d-block nested-menu-link py-1">Áo len nam</a>
                                                    <a href="/Products/Index?categoryId=5" class="d-block nested-menu-link py-1">Áo hoodie - Áo nỉ nam</a>
                                                    <a href="/Products/Index?categoryId=6" class="d-block nested-menu-link py-1">Áo khoác nam</a>
                                                </div>
                                            </li>
                                            <!-- Quần Nam -->
                                            <li class="mb-2">
                                                 <div class="d-flex justify-content-between align-items-center menu-toggle" data-bs-toggle="collapse" data-bs-target="#collapseQuanNam" aria-expanded="false" onclick="event.stopPropagation()">
                                                    <span>Quần nam</span>
                                                    <i class="bi bi-chevron-down small"></i>
                                                </div>
                                                <div class="collapse ps-3 mt-1" id="collapseQuanNam">
                                                    <a href="/Products/Index?keyword=Quần Nam" class="d-block nested-menu-link py-1">Tất cả Quần nam</a>
                                                    <a href="/Products/Index?categoryId=7" class="d-block nested-menu-link py-1">Quần Jeans nam</a>
                                                    <a href="/Products/Index?categoryId=8" class="d-block nested-menu-link py-1">Quần Tây nam</a>
                                                    <a href="/Products/Index?categoryId=9" class="d-block nested-menu-link py-1">Quần Kaki nam</a>
                                                    <a href="/Products/Index?categoryId=10" class="d-block nested-menu-link py-1">Quần Short nam</a>
                                                </div>
                                            </li>
                                            <!-- Other Items -->
                                            <li class="mb-2"><a href="/Products/Index?categoryId=11" class="text-decoration-none text-dark d-block hover-link">Đồ thể thao nam</a></li>
                                        </ul>
                                    </div>
                                    <!-- NU Column -->
                                    <div class="col-md-4">
                                        <h6 class="fw-bold text-uppercase mb-3 border-bottom pb-2">Nữ <i class="bi bi-arrow-up-right small"></i></h6>
                                         <ul class="list-unstyled">
                                            <!-- Áo Nữ -->
                                            <li class="mb-2">
                                                <div class="d-flex justify-content-between align-items-center menu-toggle" data-bs-toggle="collapse" data-bs-target="#collapseAoNu" aria-expanded="false" onclick="event.stopPropagation()">
                                                    <span>Áo nữ</span>
                                                    <i class="bi bi-chevron-down small"></i>
                                                </div>
                                                <div class="collapse ps-3 mt-1" id="collapseAoNu">
                                                    <a href="/Products/Index?keyword=Áo Nữ" class="d-block nested-menu-link py-1">Tất cả Áo nữ</a>
                                                    <a href="/Products/Index?categoryId=13" class="d-block nested-menu-link py-1">Áo sơ mi nữ</a>
                                                    <a href="/Products/Index?categoryId=14" class="d-block nested-menu-link py-1">Áo thun nữ</a>
                                                    <a href="/Products/Index?categoryId=15" class="d-block nested-menu-link py-1">Áo polo nữ</a>
                                                    <a href="/Products/Index?categoryId=16" class="d-block nested-menu-link py-1">Áo len nữ</a>
                                                    <a href="/Products/Index?categoryId=17" class="d-block nested-menu-link py-1">Áo khoác nữ</a>
                                                </div>
                                            </li>
                                            <!-- Quần Nữ -->
                                            <li class="mb-2">
                                                 <div class="d-flex justify-content-between align-items-center menu-toggle" data-bs-toggle="collapse" data-bs-target="#collapseQuanNu" aria-expanded="false" onclick="event.stopPropagation()">
                                                    <span>Quần nữ</span>
                                                    <i class="bi bi-chevron-down small"></i>
                                                </div>
                                                <div class="collapse ps-3 mt-1" id="collapseQuanNu">
                                                    <a href="/Products/Index?keyword=Quần Nữ" class="d-block nested-menu-link py-1">Tất cả Quần nữ</a>
                                                    <a href="/Products/Index?categoryId=18" class="d-block nested-menu-link py-1">Quần Jeans nữ</a>
                                                    <a href="/Products/Index?categoryId=19" class="d-block nested-menu-link py-1">Quần Âu nữ</a>
                                                    <a href="/Products/Index?categoryId=20" class="d-block nested-menu-link py-1">Quần Kaki nữ</a>
                                                </div>
                                            </li>
                                            <!-- Váy Đầm -->
                                            <li class="mb-2">
                                                 <div class="d-flex justify-content-between align-items-center menu-toggle" data-bs-toggle="collapse" data-bs-target="#collapseVayNu" aria-expanded="false" onclick="event.stopPropagation()">
                                                    <span>Váy nữ</span>
                                                    <i class="bi bi-chevron-down small"></i>
                                                </div>
                                                <div class="collapse ps-3 mt-1" id="collapseVayNu">
                                                    <a href="/Products/Index?categoryId=21" class="d-block nested-menu-link py-1">Chân váy</a>
                                                    <a href="/Products/Index?categoryId=22" class="d-block nested-menu-link py-1">Đầm thời trang</a>
                                                </div>
                                            </li>
                                        </ul>
                                    </div>
                                    <!-- TRE EM Column -->
                                    <div class="col-md-4">
                                        <h6 class="fw-bold text-uppercase mb-3 border-bottom pb-2">Trẻ Em <i class="bi bi-arrow-up-right small"></i></h6>
                                        <ul class="list-unstyled">
                                            <li class="mb-2"><a href="/Products/Index?categoryId=23" class="text-decoration-none text-dark d-block hover-link">Áo trẻ em</a></li>
                                            <li class="mb-2"><a href="/Products/Index?categoryId=24" class="text-decoration-none text-dark d-block hover-link">Quần trẻ em</a></li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Center: Logo -->
                <div class="col-md-6 text-center">
                    <a asp-controller="Home" asp-action="Index" class="text-decoration-none">
                        <img src="@Url.Content("~/images/logo.png")" alt="HOAHONGXANH" style="height: 50px; width: auto; object-fit: contain;">
                    </a>
                </div>

                <!-- Right: Search & Icons -->
                <div class="col-md-3 d-flex justify-content-end align-items-center gap-3">
                    <form asp-controller="Products" asp-action="Index" method="get" class="d-flex position-relative me-2">
                        <input type="text" name="keyword" class="form-control rounded-pill ps-4 pe-5" placeholder="Tìm kiếm" style="width: 200px;">
                        <button type="submit" class="btn position-absolute end-0 top-0 h-100 border-0 bg-transparent rounded-pill px-3">
                            <i class="bi bi-search"></i>
                        </button>
                    </form>

                    <div class="position-relative cart-wrapper">
                        <a asp-controller="Cart" asp-action="Index" class="position-relative text-dark fs-5">
                           <i class="bi bi-bag"></i>
                           <!-- We can verify Cart count via ViewComponent later, static for now -->
                        </a>
                        <div id="mini-cart-container" class="position-absolute top-100 end-0 pt-2" style="display: none; z-index: 1000;"></div>
                    </div>
                    
                    @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
                    {
                        <a asp-controller="Admin" asp-action="Dashboard" class="btn btn-dark rounded-pill me-3 fw-bold text-white text-nowrap d-flex align-items-center" style="font-size: 0.8rem; padding: 6px 16px;">
                            <i class="bi bi-shield-lock-fill me-2"></i>QUẢN TRỊ
                        </a>
                    }
                    
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                         <div class="dropdown">
                            <a href="#" class="text-dark fs-5" id="userDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-person-circle"></i>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                                <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile">Hồ sơ (@User.Identity.Name)</a></li>
                                <li><a class="dropdown-item" asp-controller="Account" asp-action="Logout">Đăng xuất</a></li>
                            </ul>
                        </div>
                    }
                    else
                    {
                          <a asp-controller="Account" asp-action="Login" class="text-dark fs-5 d-flex align-items-center text-decoration-none">
                            <i class="bi bi-person me-1"></i> <span class="fs-6 d-none d-lg-inline">Đăng nhập</span>
                        </a>
                    }
                </div>
            </div>
            
             <!-- Optional: Quick Links Row below (like in the image) -->

        </div>
    </header>

    <div class="container-fluid p-0 flex-grow-1">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-dark mt-5">
        <div class="container">
            <!-- Top Section: Listening & Contact -->
            <div class="row align-items-center mb-4">
                <div class="col-md-6 mb-3 mb-md-0">
                    <h4 class="fw-bold mb-2">HOAHONGXANH lắng nghe bạn!</h4>
                    <p class="mb-3 text-secondary">Chúng tôi luôn trân trọng mọi ý kiến đóng góp từ khách hàng để cải thiện dịch vụ tốt hơn.</p>
                    <a href="#" class="footer-btn">ĐÓNG GÓP Ý KIẾN <i class="bi bi-arrow-right ms-2"></i></a>
                </div>
                <div class="col-md-6 text-md-end">
                    <div class="mb-2">
                        <span class="d-block d-md-inline me-md-4"><i class="bi bi-telephone text-white me-2"></i> hotline <strong>1900.272737</strong></span>
                        <span class="d-block d-md-inline"><i class="bi bi-envelope text-white me-2"></i> email <strong>cool@hoahongxanh.vn</strong></span>
                    </div>
                    <div class="mt-3">
                        <a href="#" class="footer-social-icon"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="footer-social-icon"><i class="bi bi-instagram"></i></a>
                        <a href="#" class="footer-social-icon"><i class="bi bi-tiktok"></i></a>
                        <a href="#" class="footer-social-icon"><i class="bi bi-youtube"></i></a>
                    </div>
                </div>
            </div>

            <hr class="footer-divider">

            <!-- Main Links Section -->
            <div class="row">
                <div class="col-md-3 mb-4">
                    <h6 class="text-white">VỀ HOAHONGXANH</h6>
                    <ul>
                        <li><a href="#">Câu chuyện thương hiệu</a></li>
                        <li><a href="#">Tuyển dụng</a></li>
                        <li><a href="#">Blog thời trang</a></li>
                        <li><a href="#">Chuỗi cửa hàng</a></li>
                    </ul>
                </div>
                <div class="col-md-3 mb-4">
                    <h6 class="text-white">CHÍNH SÁCH</h6>
                    <ul>
                        <li><a href="#">Chính sách đổi trả</a></li>
                        <li><a href="#">Chính sách bảo mật</a></li>
                        <li><a href="#">Chính sách vận chuyển</a></li>
                        <li><a href="#">Khách hàng thân thiết</a></li>
                    </ul>
                </div>
                <div class="col-md-3 mb-4">
                    <h6 class="text-white">HỖ TRỢ KHÁCH HÀNG</h6>
                    <ul>
                        <li><a href="#">Hướng dẫn chọn size</a></li>
                        <li><a href="#">Hướng dẫn mua hàng</a></li>
                        <li><a href="#">Câu hỏi thường gặp</a></li>
                        <li><a href="#">Kiểm tra đơn hàng</a></li>
                    </ul>
                </div>
                <div class="col-md-3 mb-4">
                    <h6 class="text-white">ĐỊA CHỈ LIÊN HỆ</h6>
                    <p class="small text-secondary mb-2">Văn phòng Hà Nội: Tầng 3, Tòa nhà BMM, Km2, Đường Phùng Hưng, Phường Hà Đông, Hà Nội</p>
                    <p class="small text-secondary">Văn phòng TP.HCM: Lô C3, đường D2, KCN Cát Lái, TP.Thủ Đức, TP.HCM</p>
                </div>
            </div>

            <hr class="footer-divider my-4">

            <!-- Bottom Section -->
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start mb-2 mb-md-0">
                    <p class="footer-bottom-text mb-0">&copy; 2025 CÔNG TY TNHH HOAHONGXANH. All rights reserved.</p>
                    <p class="footer-bottom-text small mb-0">Mã số doanh nghiệp: 0108617038. Cấp ngày 20/02/2019.</p>
                </div>
                <div class="col-md-6 text-center text-md-end">
                     <!-- Using placeholders for certification badges as per image style -->
                    <span class="d-inline-block bg-white p-1 rounded me-2 opacity-75"><i class="bi bi-shield-check text-primary fs-4"></i></span>
                    <span class="d-inline-block bg-white p-1 rounded opacity-75"><i class="bi bi-award text-danger fs-4"></i></span>
                </div>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        function toggleMegaMenu() {
            var menu = document.getElementById('megaMenuContent');
            menu.classList.toggle('show');
        }

        // Close menu when clicking outside
        document.addEventListener('click', function(event) {
            var menu = document.getElementById('megaMenuContent');
            var btn = document.getElementById('megaMenuBtn');
            if (!menu.contains(event.target) && !btn.contains(event.target)) {
                menu.classList.remove('show');
            }
        });
    </script>
    <partial name="_GlobalScripts" />
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
