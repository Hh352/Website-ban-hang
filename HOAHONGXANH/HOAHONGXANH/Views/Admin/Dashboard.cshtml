@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Tổng Quan";
}

<!-- Stats Overview -->
<div class="row g-4 mb-4">
    <!-- Customers -->
    <div class="col-md-3">
        <div class="db-card d-flex flex-column justify-content-between">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div class="border-start border-4 border-primary ps-3" style="border-color: #3699FF !important;">
                     <div class="db-card-title mb-1">Khách hàng</div>
                     <div class="db-stat-value">@ViewBag.TotalCustomers.ToString("N0")</div>
                </div>
                <div class="db-stat-icon blue">
                    <i class="bi bi-people-fill"></i>
                </div>
            </div>
             <div class="text-success small fw-bold">
                 <i class="bi bi-arrow-up"></i> +6.5% <span class="text-muted fw-normal ms-1">So với tuần trước</span>
            </div>
        </div>
    </div>
    
    <!-- Revenue -->
     <div class="col-md-3">
        <div class="db-card d-flex flex-column justify-content-between">
             <div class="d-flex justify-content-between align-items-start mb-3">
                <div class="border-start border-4 border-success ps-3" style="border-color: #1BC5BD !important;">
                     <div class="db-card-title mb-1">Doanh thu</div>
                     <div class="db-stat-value">@(((decimal)ViewBag.TotalRevenue).ToString("N0"))đ</div>
                </div>
                <div class="db-stat-icon green">
                    <i class="bi bi-wallet2"></i>
                </div>
            </div>
             <div class="text-danger small fw-bold">
                 <i class="bi bi-arrow-down"></i> -0.10% <span class="text-muted fw-normal ms-1">So với tuần trước</span>
            </div>
        </div>
    </div>
    
    <!-- Profit -->
     <div class="col-md-3">
        <div class="db-card d-flex flex-column justify-content-between">
             <div class="d-flex justify-content-between align-items-start mb-3">
                <div class="border-start border-4 border-primary ps-3" style="border-color: #8950FC !important;">
                     <div class="db-card-title mb-1">Lợi nhuận</div>
                     <div class="db-stat-value">60%</div>
                </div>
                <div class="db-stat-icon purple">
                    <i class="bi bi-box-fill"></i>
                </div>
            </div>
             <div class="text-danger small fw-bold">
                 <i class="bi bi-arrow-down"></i> -0.2% <span class="text-muted fw-normal ms-1">So với tuần trước</span>
            </div>
        </div>
    </div>
    
     <!-- Invoices -->
     <div class="col-md-3">
        <div class="db-card d-flex flex-column justify-content-between">
             <div class="d-flex justify-content-between align-items-start mb-3">
                <div class="border-start border-4 border-warning ps-3" style="border-color: #FFA800 !important;">
                     <div class="db-card-title mb-1">Hóa đơn</div>
                     <div class="db-stat-value">1.135</div>
                </div>
                <div class="db-stat-icon yellow">
                    <i class="bi bi-file-text-fill"></i>
                </div>
            </div>
             <div class="text-success small fw-bold">
                 <i class="bi bi-arrow-up"></i> +11.5% <span class="text-muted fw-normal ms-1">So với tuần trước</span>
            </div>
        </div>
    </div>
</div>

<!-- Charts Section -->
<div class="row g-4 mb-4">
    <div class="col-md-5">
         <div class="db-card">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h6 class="fw-bold m-0">Thống kê hóa đơn</h6>
                <i class="bi bi-three-dots text-muted cursor-pointer"></i>
            </div>
            
            <div class="d-flex align-items-center justify-content-center position-relative my-4" style="height: 250px;">
                <!-- Simple CSS Donut Chart representation -->
                 <div class="position-relative d-flex align-items-center justify-content-center" style="width: 200px; height: 200px; border-radius: 50%; background: conic-gradient(#3699FF 0% 40%, #E1F0FF 40% 100%);">
                     <div class="bg-white d-flex flex-column align-items-center justify-content-center shadow-sm" style="width: 140px; height: 140px; border-radius: 50%;">
                         <div class="fs-4 fw-bold">1.135</div>
                         <div class="text-muted small">Hóa đơn</div>
                     </div>
                      <!-- Tooltip-like label -->
                      <div class="position-absolute bg-dark text-white p-2 rounded small end-0 top-0 shadow" style="font-size: 0.7rem;">
                          Đã thanh toán <span class="text-warning">●</span> 234
                      </div>
                 </div>
            </div>
         </div>
    </div>
    
    <div class="col-md-7">
        <div class="db-card">
             <div class="d-flex justify-content-between align-items-center mb-4">
                <h6 class="fw-bold m-0">Phân tích bán hàng</h6>
                <i class="bi bi-three-dots text-muted cursor-pointer"></i>
            </div>
            
            <!-- Simplified Line Chart visual -->
            <div class="position-relative w-100" style="height: 250px; background-image: linear-gradient(to right, #f8f9fa 1px, transparent 1px), linear-gradient(to bottom, #f8f9fa 1px, transparent 1px); background-size: 40px 40px;">
                 <svg viewBox="0 0 100 50" preserveAspectRatio="none" style="width: 100%; height: 100%;">
                    <polyline points="0,40 10,35 20,42 30,38 40,25 50,35 60,30 70,32 80,32 90,45 100,40" 
                              fill="none" stroke="#8950FC" stroke-width="0.5" />
                     <circle cx="40" cy="25" r="1.5" fill="#1E1E2D" stroke="#fff" stroke-width="0.5" />
                 </svg>
                 
                  <div class="position-absolute bg-dark text-white px-2 py-1 rounded small shadow" style="left: 38%; top: 40%; transform: translateX(-50%); font-size: 0.7rem;">
                      <span class="text-success me-1">●</span> $1,134
                  </div>
            </div>
            
             <div class="d-flex justify-content-between text-muted small mt-2">
                 <span>Th1</span><span>Th2</span><span>Th3</span><span class="text-dark fw-bold border-bottom border-2 border-dark">Th4</span><span>Th5</span><span>Th6</span><span>Th7</span><span>Th8</span><span>Th9</span><span>Th10</span><span>Th11</span><span>Th12</span>
             </div>
        </div>
    </div>
</div>

<!-- Recent Invoices Table -->
<div class="row">
    <div class="col-12">
        <div class="db-card">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h6 class="fw-bold m-0">Hóa đơn gần đây</h6>
                <div class="d-flex gap-2">
                    <button class="btn btn-sm btn-light border"><i class="bi bi-filter"></i> Lọc</button>
                    <button class="btn btn-sm btn-light border"><i class="bi bi-three-dots"></i></button>
                </div>
            </div>
            
             <div class="table-responsive">
                <table class="table table-borderless align-middle mb-0">
                    <thead class="text-muted small text-uppercase">
                        <tr>
                            <th>STT</th>
                            <th>Mã KH</th>
                            <th>Tên Khách Hàng</th>
                            <th>Sản phẩm</th>
                            <th>Ngày đặt</th>
                            <th>Trạng thái</th>
                            <th class="text-end">Giá</th>
                        </tr>
                    </thead>
                    <tbody>
                         <tr class="border-bottom">
                            <td>1</td>
                            <td class="fw-bold text-primary">#065499</td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                     <img src="https://i.pravatar.cc/150?img=11" class="rounded-circle" width="30" height="30">
                                     <span class="fw-bold fs-6">Nguyễn Văn An</span>
                                </div>
                            </td>
                            <td>1x Balo Đen Cao Cấp</td>
                            <td>21/07/2022 08:21</td>
                            <td><span class="db-badge paid">Đã thanh toán</span></td>
                            <td class="text-end fw-bold">2.500.000đ</td>
                        </tr>
                        <tr class="border-bottom">
                            <td>2</td>
                            <td class="fw-bold text-primary">#065499</td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                     <img src="https://i.pravatar.cc/150?img=12" class="rounded-circle" width="30" height="30">
                                     <span class="fw-bold fs-6">Trần Thị Bích</span>
                                </div>
                            </td>
                            <td>1x Balo Thời Trang</td>
                            <td>21/07/2022 08:21</td>
                            <td><span class="db-badge pending">Chờ xử lý</span></td>
                            <td class="text-end fw-bold">3.200.000đ</td>
                        </tr>
                         <tr class="border-bottom">
                            <td>3</td>
                            <td class="fw-bold text-primary">#065499</td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                     <img src="https://i.pravatar.cc/150?img=13" class="rounded-circle" width="30" height="30">
                                     <span class="fw-bold fs-6">Lê Hoàng Nam</span>
                                </div>
                            </td>
                            <td>1x Balo Laptop</td>
                            <td>21/07/2022 08:21</td>
                            <td><span class="db-badge paid">Đã thanh toán</span></td>
                            <td class="text-end fw-bold">1.800.000đ</td>
                        </tr>
                         <tr>
                            <td>4</td>
                            <td class="fw-bold text-primary">#065499</td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                     <img src="https://i.pravatar.cc/150?img=14" class="rounded-circle" width="30" height="30">
                                     <span class="fw-bold fs-6">Phạm Minh Tú</span>
                                </div>
                            </td>
                            <td>2x Balo Du Lịch</td>
                            <td>21/07/2022 08:21</td>
                            <td><span class="db-badge overdue">Quá hạn</span></td>
                            <td class="text-end fw-bold">6.000.000đ</td>
                        </tr>
                    </tbody>
                </table>
             </div>
        </div>
    </div>
</div>
