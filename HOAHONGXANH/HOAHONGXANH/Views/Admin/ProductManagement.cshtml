@model List<HOAHONGXANH.Models.Product>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Quản Lý Sản Phẩm";
}

<!-- PickPlant Header -->
<div class="d-flex justify-content-between align-items-center mb-4 mt-3">
    <a href="@Url.Action("CreateProduct", "Admin")" class="btn btn-primary rounded-pill px-4 shadow-sm fw-bold">
        <i class="bi bi-plus-lg me-2"></i>Thêm sản phẩm
    </a>
    <div class="d-flex gap-3">
         <div class="dropdown">
            <button class="btn btn-white border shadow-sm dropdown-toggle rounded-pill px-3" type="button" data-bs-toggle="dropdown">
                Ngày tạo
            </button>
        </div>
         <div class="dropdown">
            <button class="btn btn-white border shadow-sm dropdown-toggle rounded-pill px-3" type="button" data-bs-toggle="dropdown">
                Trạng thái
            </button>
        </div>
        <div class="btn-group bg-light rounded-pill p-1" role="group">
             <button type="button" class="btn btn-white rounded-pill shadow-sm px-3 py-1 text-success fw-bold">Danh sách</button>
             <button type="button" class="btn btn-light rounded-pill px-3 py-1 border-0 text-muted">Thẻ</button>
        </div>
    </div>
</div>

<!-- PickPlant Table Container -->
<div class="pp-table-container">
    <table class="pp-table">
        <thead>
            <tr>
                <th style="width: 50px;" class="text-center">
                    <input type="checkbox" class="pp-checkbox">
                </th>
                <th>ID</th>
                <th>Sản phẩm</th>
                <th>Ngày tạo</th>
                <th>Danh mục</th>
                <th>Giá bán</th>
                <th>Trạng thái</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
             @foreach (var item in Model)
            {
                <tr class="pp-row">
                    <td class="text-center">
                        <input type="checkbox" class="pp-checkbox">
                    </td>
                    <td class="fw-bold text-muted">#@item.Id</td>
                    <td>
                        <div class="d-flex align-items-center gap-3">
                            <img src="@item.Image" alt="@item.Name" class="rounded-3 shadow-sm" style="width: 45px; height: 45px; object-fit: cover;">
                            <span class="fw-bold text-dark">@item.Name</span>
                        </div>
                    </td>
                    <td>
                        <div class="d-flex flex-column">
                            <span class="fw-bold text-dark" style="font-size: 0.9rem;">@DateTime.Now.ToString("dd/MM/yyyy")</span>
                            <span class="text-muted" style="font-size: 0.75rem;">12:00:43</span>
                        </div>
                    </td>
                    <td class="text-dark">@item.CategoryName</td>
                    <td class="text-dark fw-bold">@item.Price.ToString("N0")đ</td>
                    <td>
                         @if (item.Stock > 10)
                        {
                            <span class="pp-status active">Còn hàng</span>
                        }
                        else if (item.Stock > 0)
                        {
                            <span class="pp-status pending">Sắp hết</span>
                        }
                        else
                        {
                            <span class="pp-status blocked">Hết hàng</span>
                        }
                    </td>
                    <td class="text-end pe-4">
                        <div class="dropdown">
                             <button class="btn pp-action-btn" type="button" data-bs-toggle="dropdown">
                                <i class="bi bi-three-dots"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-4 mt-2">
                                <li><a class="dropdown-item py-2" href="/Admin/EditProduct/@item.Id"><i class="bi bi-pencil me-2"></i>Sửa sản phẩm</a></li>
                                <li><a class="dropdown-item py-2 text-danger" href="/Admin/DeleteProduct/@item.Id" onclick="return confirm('Xóa sản phẩm này?');"><i class="bi bi-trash me-2"></i>Xóa sản phẩm</a></li>
                            </ul>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    
    <!-- Pagination -->
    <div class="d-flex justify-content-center mt-5 mb-5">
         <nav class="pp-pagination">
            <ul class="pagination mb-0 align-items-center">
                <li class="page-item disabled"><a class="page-link border-0" href="#">Trước</a></li>
                <li class="page-item active"><a class="page-link shadow-sm" href="#">1</a></li>
                <li class="page-item"><a class="page-link" href="#">2</a></li>
                <li class="page-item"><a class="page-link" href="#">3</a></li>
                <li class="page-item"><span class="mx-2 text-muted">...</span></li>
                <li class="page-item"><a class="page-link" href="#">15</a></li>
                <li class="page-item"><a class="page-link border-0" href="#">Sau</a></li>
            </ul>
        </nav>
    </div>
</div>
