@model List<HOAHONGXANH.Models.CartItem>
@{
    ViewData["Title"] = "Giỏ Hàng";
    decimal grandTotal = 0;
    if (Model != null)
    {
        grandTotal = Model.Sum(x => x.Total);
    }
}

<div class="container py-5 bg-light" style="min-height: 80vh;">
    <div class="d-flex align-items-center mb-4">
        <h4 class="fw-bold mb-0">Giỏ hàng</h4>
        <span class="text-muted ms-2">(@(Model?.Count ?? 0) sản phẩm)</span>
    </div>

    @if (Model == null || Model.Count == 0)
    {
        <div class="text-center py-5 bg-white rounded shadow-sm">
            <img src="https://cdni.iconscout.com/illustration/premium/thumb/empty-cart-2130356-1800917.png" alt="Empty Cart" style="width: 200px; opacity: 0.7;">
            <h5 class="fw-bold mt-3">Giỏ hàng của bạn đang trống</h5>
            <p class="text-muted">Hãy chọn thêm sản phẩm để mua sắm nhé</p>
            <a href="/Home/Index" class="btn btn-warning text-white fw-bold px-4 py-2 mt-2" style="background-color: #FCAF17;">Quay lại mua sắm</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            <!-- Left Column: Cart Items -->
            <div class="col-lg-8">
                <div class="bg-white rounded shadow-sm p-3 mb-3 d-flex align-items-center">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="selectAll" checked>
                        <label class="form-check-label fw-bold small" for="selectAll">Chọn tất cả (@Model.Count sản phẩm)</label>
                    </div>
                </div>

                <div class="bg-white rounded shadow-sm">
                    @foreach (var item in Model)
                    {
                        <div class="p-3 border-bottom position-relative">
                            <div class="row align-items-center">
                                <!-- Checkbox -->
                                <div class="col-1 text-center">
                                    <input class="form-check-input" type="checkbox" checked>
                                </div>
                                
                                <!-- Image -->
                                <div class="col-3 col-md-2">
                                    <img src="@item.Image" alt="@item.ProductName" class="img-fluid rounded" style="width: 100%; height: auto; object-fit: cover;">
                                </div>

                                <!-- Info -->
                                <div class="col-8 col-md-9">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <h6 class="fw-bold mb-1 text-truncate" style="max-width: 300px;">
                                                <a href="/Products/Details/@item.ProductId" class="text-dark text-decoration-none">@item.ProductName</a>
                                            </h6>
                                            <p class="text-muted small mb-2">@item.Color, @item.Size</p>
                                        </div>
                                        <div class="text-end">
                                            <a href="/Cart/RemoveFromCart/@item.ProductId" class="text-muted" onclick="return confirm('Xóa sản phẩm này?');">
                                                <i class="bi bi-trash fs-5"></i>
                                            </a>
                                        </div>
                                    </div>

                                    <div class="d-flex justify-content-between align-items-end mt-2">
                                        <!-- Price -->
                                        <span class="fw-bold fs-5">@item.Price.ToString("N0")đ</span>
                                        
                                        <!-- Quantity Form -->
                                        <form asp-action="UpdateCart" method="post" class="d-flex align-items-center">
                                            <input type="hidden" name="id" value="@item.ProductId" />
                                            <div class="input-group input-group-sm" style="width: 100px;">
                                                <button class="btn btn-outline-secondary" type="button" onclick="this.nextElementSibling.stepDown(); this.form.submit();">-</button>
                                                <input type="number" name="quantity" value="@item.Quantity" min="1" class="form-control text-center border-secondary fw-bold p-0" onchange="this.form.submit()">
                                                <button class="btn btn-outline-secondary" type="button" onclick="this.previousElementSibling.stepUp(); this.form.submit();">+</button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Right Column: Summary -->
            <div class="col-lg-4">
                <div class="bg-white rounded shadow-sm p-4 sticky-top" style="top: 20px;">
                    <h5 class="fw-bold mb-3">Chi tiết đơn hàng</h5>
                    
                    <div class="d-flex justify-content-between mb-2 small text-muted">
                        <span>Tổng tiền hàng</span>
                        <span>@grandTotal.ToString("N0")đ</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3 small text-muted">
                        <span>Giảm giá</span>
                        <span>0đ</span>
                    </div>

                    <div class="border-top pt-3 d-flex justify-content-between align-items-center mb-4">
                        <span class="fw-bold">Thành tiền</span>
                        <div class="text-end">
                            <span class="fw-bold text-danger fs-4 d-block">@grandTotal.ToString("N0")đ</span>
                            <span class="text-muted small d-block">Đã bao gồm VAT</span>
                        </div>
                    </div>

                    <a href="/Cart/Checkout" class="btn btn-warning text-white fw-bold w-100 py-3 text-uppercase" style="background-color: #FCAF17;">
                        Đặt Hàng <i class="bi bi-arrow-right ms-2"></i>
                    </a>
                    
                    <div class="mt-3 text-center small text-muted">
                        <i class="bi bi-truck me-1"></i>
                        Đơn hàng từ 498k được <span class="fw-bold text-success">miễn phí vận chuyển</span> nhé!
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    /* Custom Scrollbar for quantity inputs if needed, though hidden by standard bootstrap */
    input[type=number]::-webkit-inner-spin-button, 
    input[type=number]::-webkit-outer-spin-button { 
        -webkit-appearance: none; 
        margin: 0; 
    }
</style>
