@model int
@{
    ViewData["Title"] = "Đặt hàng thành công";
}

<div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="text-center bg-white p-5 rounded shadow-sm" style="max-width: 500px; width: 100%;">
        
        <!-- Icon: Black Circle with proper checkmark -->
        <div class="mb-4 d-flex justify-content-center">
            <div class="rounded-circle d-flex align-items-center justify-content-center" 
                 style="width: 100px; height: 100px; background-color: #000000;">
                <!-- Using Bootstrap Icon Check or custom SVG -->
                <i class="bi bi-check-lg text-white" style="font-size: 50px;"></i>
            </div>
        </div>

        <h2 class="fw-bold mb-3 text-uppercase">THÀNH CÔNG !</h2>
        <p class="text-muted mb-5">Cảm ơn bạn đã mua hàng.</p>

        <a href="/Home/Index" class="btn btn-warning text-white fw-bold w-100 py-3 text-uppercase" style="background-color: #FCAF17; border-radius: 0;">
            TIẾP TỤC MUA HÀNG
        </a>
    </div>
</div>
