@{
    ViewData["Title"] = "Đăng Nhập";
}

<div class="d-flex justify-content-center align-items-center py-5">
    <div class="login-container shadow-lg" style="max-width: 900px; width: 100%; min-height: 600px;">
        <!-- Left Side: Form -->
        <div class="login-left p-5">
            <div class="login-brand mb-4">
                <i class="bi bi-circle-fill"></i> HOAHONGXANH 
            </div>

            <div class="login-header mb-4">
                <h1>Chào mừng trở lại</h1>
                <p>Chào mừng! Vui lòng nhập thông tin của bạn.</p>
            </div>

             @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger mb-4">@ViewBag.Error</div>
            }

            <form asp-action="Login" method="post" class="login-form">
                <div class="mb-3">
                    <label class="form-label">Tên đăng nhập / Email</label>
                    <input type="text" name="username" class="form-control" placeholder="Nhập email của bạn" required />
                </div>
                <div class="mb-4">
                    <label class="form-label">Mật khẩu</label>
                    <input type="password" name="password" class="form-control" placeholder="••••••••" required />
                </div>

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="rememberMe" name="rememberMe">
                        <label class="form-check-label text-muted small" for="rememberMe">
                            Ghi nhớ cho 30 ngày
                        </label>
                    </div>
                </div>

                <button type="submit" class="btn btn-login-yellow w-100">Đăng Nhập</button>
            </form>

            <div class="mt-4 text-center text-muted small">
                Chưa có tài khoản? <a href="/Account/Register" class="text-dark fw-bold text-decoration-none">Đăng ký</a>
            </div>
        </div>

        <!-- Right Side: Visual -->
        <div class="login-right d-none d-md-block" style="background-color: #f8f9fa; position: relative; overflow: hidden;">
            <!-- Maple Leaf Logo Logo -->
            <img src="~/images/maple-leaf.png" alt="Logo" class="login-logo-hero position-absolute top-50 start-50 translate-middle" style="max-width: 60%; opacity: 0.8;" />
        </div>
    </div>
</div>
